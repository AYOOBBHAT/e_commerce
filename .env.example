# MongoDB — copy to .env.local (never commit real credentials)
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/DATABASE?retryWrites=true&w=majorit

# Category system — set true after running npm run seed:categories
USE_DB_CATEGORIES=false

# Redis (optional)
REDIS_URL=
REDIS_REST_TOKEN=

# Cloudinary (category image uploads)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=
# Server-only — required to delete replaced category images from Cloudinary
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
